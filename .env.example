# VCF Automation connection settings
VCFA_HOST=vcfa.example.com
VCFA_USERNAME=administrator
VCFA_ORGANIZATION=your-organization-here
VCFA_PASSWORD=your-password-here

# Set to "true" to allow self-signed TLS certificates (common in lab environments)
VCFA_IGNORE_TLS=false

# Optional local directories for artifact import/export files
# VCFA_PACKAGE_DIR=/tmp/mcp-vcf-orchestrator/packages
# VCFA_RESOURCE_DIR=/tmp/mcp-vcf-orchestrator/resources
# VCFA_WORKFLOW_DIR=/tmp/mcp-vcf-orchestrator/workflows
# VCFA_ACTION_DIR=/tmp/mcp-vcf-orchestrator/actions
# VCFA_CONFIGURATION_DIR=/tmp/mcp-vcf-orchestrator/configurations
