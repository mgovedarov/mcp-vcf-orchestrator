{
  "name": "@mgovedarov/mcp-vcf-orchestrator",
  "version": "1.0.0",
  "description": "MCP server for VCF Automation Orchestrator — manage workflows, actions, configuration elements, and extensibility subscriptions via AI assistants",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-vcf-orchestrator": "dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:coverage": "npm run build && node --test --experimental-test-coverage test/*.test.mjs",
    "prepublishOnly": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "vcf",
    "vro",
    "orchestrator",
    "vmware",
    "automation",
    "aria",
    "extensibility"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mgovedarov/mcp-vcf-orchestrator.git"
  },
  "homepage": "https://github.com/mgovedarov/mcp-vcf-orchestrator#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.7.2",
    "fflate": "^0.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
